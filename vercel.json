{
  "version": 2,
  "builds": [
    { "src": "frontend/react-app/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/_supabase_debug", "dest": "/api/_supabase_debug.py" },
    { "src": "/(.*)", "dest": "/frontend/react-app/$1" }
  ]
}
